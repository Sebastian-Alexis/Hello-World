---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.status === 'published');
const posts = allPosts.sort((a, b) =>
  new Date(b.data.published_at).getTime() - new Date(a.data.published_at).getTime()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  });
}

function getPreviewHtml(body: string): string {
  const text = body
    .replace(/^---[\s\S]*?---/, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]*)\]\(.*?\)/g, '$1')
    .replace(/#{1,6}\s+/g, '')
    .replace(/[*_~`>]/g, '')
    .replace(/\*\*/g, '')
    .trim();
  return text
    .split(/\n{2,}/)
    .filter(p => p.trim())
    .map(p => `<p>${p.replace(/\n/g, '<br>')}</p>`)
    .join('');
}
---

<BaseLayout
  title="Home"
  description="UC Berkeley student studying applied math and cybersecurity."
>
  <div class="container mx-auto max-w-3xl px-4">
    <!-- Intro -->
    <p class="text-lg text-text-primary pt-6 pb-10 leading-relaxed">
      UC Berkeley student studying applied math and cybersecurity. I like to build stuff, and I talk about it here. See my <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="underline hover:opacity-70 transition-opacity">resume</a> and my <a href="/work" class="underline hover:opacity-70 transition-opacity">work</a>.
    </p>

    <!-- Blog Posts -->
    {posts.length > 0 ? (
      <div class="space-y-10 pb-20">
        {posts.map((post) => (
          <article>
            <a href={`/blog/${post.slug}`} class="block group">
              <h2 class="text-2xl md:text-3xl font-medium text-text-primary group-hover:underline mb-1">
                {post.data.title}
              </h2>
            </a>
            <time class="text-sm text-text-secondary" datetime={post.data.published_at.toISOString()}>
              {formatDate(post.data.published_at)}
            </time>
            <div class={`mt-4 ${post.data.featured_image_url ? 'flex flex-col sm:flex-row gap-5' : ''}`}>
              {post.data.featured_image_url && (
                <a href={`/blog/${post.slug}`} class="flex-shrink-0">
                  <img
                    src={post.data.featured_image_url}
                    alt={post.data.title}
                    class="w-full sm:w-56 md:w-64 sm:h-56 rounded-lg object-cover"
                    loading="lazy"
                  />
                </a>
              )}
              <div class={`flex flex-col min-h-0 flex-1 ${post.data.featured_image_url ? 'sm:max-h-56' : ''}`}>
                <div class="preview-text text-text-primary leading-relaxed overflow-hidden flex-1 relative" set:html={getPreviewHtml(post.body)} />
                <a href={`/blog/${post.slug}`} class="inline-block mt-2 text-text-secondary hover:text-text-primary transition-colors flex-shrink-0">
                  Read more &#x27F6;
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="py-16 text-center">
        <p class="text-text-secondary">No posts yet. Check back soon.</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .preview-text {
    -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
  }
  .preview-text p {
    margin-bottom: 1em;
  }
</style>
