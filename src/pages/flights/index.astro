---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FlightMap from '../../components/flight-map/FlightMap.svelte';

// Import static data
import flightsData from '../../data/flights.json';
import airportsData from '../../data/airports.json';

// Get Mapbox token from environment
const mapboxToken = import.meta.env.VITE_MAPBOX_ACCESS_TOKEN || import.meta.env.PUBLIC_MAPBOX_ACCESS_TOKEN || '';

// Transform flight data for the map component
const flights = flightsData.map(f => ({
  id: f.id,
  flight_number: f.flight_number,
  airline_name: f.airline_name,
  airline_code: f.airline_code,
  departure_time: f.departure_time,
  arrival_time: f.arrival_time,
  flight_duration: f.flight_duration,
  distance_km: f.distance_km,
  flight_status: f.flight_status,
  trip_name: f.trip_name,
  departure_airport_id: f.departure_airport_id,
  arrival_airport_id: f.arrival_airport_id,
  departure_airport_name: f.departure_airport_name,
  departure_city: f.departure_city,
  departure_iata: f.departure_iata,
  departure_lat: f.departure_lat,
  departure_lng: f.departure_lng,
  arrival_airport_name: f.arrival_airport_name,
  arrival_city: f.arrival_city,
  arrival_iata: f.arrival_iata,
  arrival_lat: f.arrival_lat,
  arrival_lng: f.arrival_lng,
}));

// Transform airports for the map
const airports = airportsData.map(a => ({
  id: a.id,
  iata_code: a.iata_code,
  name: a.name,
  city: a.city,
  country: a.country,
  latitude: a.latitude,
  longitude: a.longitude,
}));

// Calculate statistics from static data
const now = new Date();
const flightStats = {
  totalFlights: flights.length,
  totalDistance: flights.reduce((sum, f) => sum + (f.distance_km || 0), 0),
  completedFlights: flights.filter(f => f.flight_status === 'completed' || new Date(f.arrival_time) < now).length,
  upcomingFlights: flights.filter(f => f.flight_status === 'booked' || new Date(f.departure_time) > now).length,
  uniqueAirlines: [...new Set(flights.map(f => f.airline_name).filter(Boolean))].length,
  visitedAirports: airports.length,
  countries: [...new Set(airports.map(a => a.country).filter(Boolean))].length,
};

// Get recent flights (last 10)
const recentFlights = [...flights]
  .sort((a, b) => new Date(b.departure_time).getTime() - new Date(a.departure_time).getTime())
  .slice(0, 10);

const currentYear = new Date().getFullYear();
---

<BaseLayout
	title="Flight Map - Interactive Travel Visualization"
	description="Explore my flight routes and airport visits with an interactive map."
>
	<!-- Hero Section with Statistics -->
	<section class="bg-white dark:bg-gray-900 py-16 border-b border-gray-200 dark:border-gray-800">
		<div class="max-w-7xl mx-auto px-4">
			<div class="text-center mb-12">
				<h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
					Flight Map
				</h1>
				<p class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto mb-8">
					An awesome 3d map that shows all flights I have been on around the world! Will continue to update as I go to events throughout my life.
				</p>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="#flight-map" class="inline-flex items-center px-6 py-3 bg-gray-900 dark:bg-white hover:bg-gray-800 dark:hover:bg-gray-100 text-white dark:text-gray-900 font-medium rounded-lg transition-all duration-200">
						<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
						</svg>
						View Flight Map
					</a>
				</div>
			</div>

			<!-- Statistics Grid -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
				<div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 text-center border border-gray-200 dark:border-gray-700">
					<div class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
						{flightStats.totalFlights}
					</div>
					<div class="text-sm font-medium text-gray-600 dark:text-gray-400">
						Total Flights
					</div>
				</div>

				<div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 text-center border border-gray-200 dark:border-gray-700">
					<div class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
						{flightStats.visitedAirports}
					</div>
					<div class="text-sm font-medium text-gray-600 dark:text-gray-400">
						Airports Visited
					</div>
				</div>

				<div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 text-center border border-gray-200 dark:border-gray-700">
					<div class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
						{(flightStats.totalDistance / 1000).toFixed(0)}K
					</div>
					<div class="text-sm font-medium text-gray-600 dark:text-gray-400">
						KM Traveled
					</div>
				</div>

				<div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 text-center border border-gray-200 dark:border-gray-700">
					<div class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
						{flightStats.countries}
					</div>
					<div class="text-sm font-medium text-gray-600 dark:text-gray-400">
						Countries
					</div>
				</div>
			</div>
		</div>
	</section>

	<main class="max-w-7xl mx-auto px-4 py-12">

		<!-- Interactive Map Section -->
		<section id="flight-map" class="mb-12 scroll-mt-20">
			<div class="mb-6">
				<h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
					Interactive Flight Map
				</h2>
				<p class="text-gray-600 dark:text-gray-400">
					See the flights I have taken. White dots represent airports, black lines represent flight paths. Hover over airports for more details.
				</p>
			</div>

			<div class="map-wrapper">
				<FlightMap
					client:load
					flights={flights}
					airports={airports}
					mapboxToken={mapboxToken}
					height="700px"
					showControls={true}
					theme="light"
				/>
			</div>
		</section>

		<!-- Recent Flights -->
		<section id="recent-flights" class="mb-12 scroll-mt-20">
			<h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
				Recent Flights
			</h2>

			<div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
				{recentFlights.length > 0 ? (
					<div class="divide-y divide-gray-200 dark:divide-gray-700">
						{recentFlights.map((flight) => (
							<div class="p-4">
								<div class="flex items-center gap-3 mb-1">
									<span class="font-semibold text-gray-900 dark:text-white">
										{flight.airline_name || 'Unknown Airline'}
									</span>
									{flight.flight_number && (
										<span class="px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 text-xs font-medium rounded">
											{flight.flight_number}
										</span>
									)}
									<span class="px-2 py-1 text-xs font-medium rounded bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
										{flight.flight_status}
									</span>
								</div>
								<p class="text-sm text-gray-600 dark:text-gray-400">
									{flight.departure_airport_name} → {flight.arrival_airport_name}
								</p>
								<p class="text-xs text-gray-500 dark:text-gray-500 mt-1">
									{new Date(flight.departure_time).toLocaleDateString('en-US', {
										year: 'numeric',
										month: 'short',
										day: 'numeric'
									})}
								</p>
							</div>
						))}
					</div>
				) : (
					<div class="px-4 py-8 text-center text-gray-500 dark:text-gray-400">
						<p>No recent flights to display</p>
					</div>
				)}
			</div>
		</section>

		<!-- Additional Statistics -->
		<section class="mb-12">
			<h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
				Flight Statistics
			</h2>

			<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
				<div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
					<div class="flex items-center justify-between mb-4">
						<h3 class="text-lg font-semibold text-gray-900 dark:text-white">
							Completed
						</h3>
					</div>
					<p class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
						{flightStats.completedFlights}
					</p>
					<p class="text-sm text-gray-600 dark:text-gray-400">
						of {flightStats.totalFlights} total flights
					</p>
				</div>

				<div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
					<div class="flex items-center justify-between mb-4">
						<h3 class="text-lg font-semibold text-gray-900 dark:text-white">
							Upcoming
						</h3>
					</div>
					<p class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
						{flightStats.upcomingFlights}
					</p>
					<p class="text-sm text-gray-600 dark:text-gray-400">
						booked flights
					</p>
				</div>

				<div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
					<div class="flex items-center justify-between mb-4">
						<h3 class="text-lg font-semibold text-gray-900 dark:text-white">
							Airlines
						</h3>
					</div>
					<p class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
						{flightStats.uniqueAirlines}
					</p>
					<p class="text-sm text-gray-600 dark:text-gray-400">
						unique airlines
					</p>
				</div>

				<div class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
					<div class="flex items-center justify-between mb-4">
						<h3 class="text-lg font-semibold text-gray-900 dark:text-white">
							This Year
						</h3>
					</div>
					<p class="text-3xl font-bold text-gray-900 dark:text-white mb-1">
						{flights.filter(f => new Date(f.departure_time).getFullYear() === currentYear).length}
					</p>
					<p class="text-sm text-gray-600 dark:text-gray-400">
						flights in {currentYear}
					</p>
				</div>
			</div>
		</section>

	</main>
</BaseLayout>

<style>
	html {
		scroll-behavior: smooth;
	}

	.map-wrapper {
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
		border: 1px solid rgb(229 231 235 / 0.5);
	}
</style>
