---
// =============================================================================
// INDIVIDUAL BLOG POST PAGE - Single blog post using Astro Content Collections
// =============================================================================

import Layout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { format } from 'date-fns';

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Format dates
const formattedDate = format(post.data.published_at, 'MMMM d, yyyy');

// Build social sharing data
const shareUrl = `${Astro.url.origin}/blog/${post.slug}`;

// Structured data for article
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "url": shareUrl,
  "datePublished": post.data.published_at.toISOString(),
  "author": {
    "@type": "Person",
    "name": "Sebastian Alexis",
  },
  ...(post.data.featured_image_url && {
    "image": {
      "@type": "ImageObject",
      "url": post.data.featured_image_url,
    }
  }),
  ...(post.data.reading_time && { "timeRequired": `PT${post.data.reading_time}M` }),
};
---

<Layout
  title={post.data.title}
  description={post.data.excerpt || `Read about ${post.data.title} on my blog.`}
  image={post.data.featured_image_url}
  structuredData={structuredData}
  type="article"
>
  <article class="min-h-screen bg-white dark:bg-gray-900">

    <!-- Hero Section -->
    <header class="bg-white dark:bg-gray-900">
      <div class="max-w-4xl mx-auto px-4 py-16 sm:py-24">

        <!-- Breadcrumb -->
        <nav class="mb-12" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-2 text-sm font-light text-gray-600 dark:text-gray-400">
            <li><a href="/" class="hover:text-black dark:hover:text-white">Home</a></li>
            <li>/</li>
            <li><a href="/" class="hover:text-black dark:hover:text-white">Blog</a></li>
          </ol>
        </nav>

        <!-- Title -->
        <h1 class="text-4xl md:text-6xl font-light tracking-tight text-black dark:text-white leading-tight mb-8">
          {post.data.title}
        </h1>

        <!-- Excerpt -->
        {post.data.excerpt && (
          <p class="text-xl font-light text-gray-600 dark:text-gray-300 leading-relaxed mb-12">
            {post.data.excerpt}
          </p>
        )}

        <!-- Post Meta -->
        <div class="text-base font-light text-gray-600 dark:text-gray-400 mb-12">
          <span>{formattedDate}</span>
          {post.data.reading_time && (
            <span> • {post.data.reading_time} min read</span>
          )}
        </div>

        <!-- Featured Image -->
        {post.data.featured_image_url && (
          <figure class="mb-16">
            <img
              src={post.data.featured_image_url}
              alt={post.data.title}
              class="w-full h-auto rounded-lg"
              loading="eager"
              decoding="async"
            />
          </figure>
        )}

      </div>
    </header>

    <!-- Article Content -->
    <div class="max-w-4xl mx-auto px-4">
      <div class="mb-16">
        <div class="prose prose-lg dark:prose-invert prose-headings:font-light prose-headings:tracking-tight prose-a:text-blue-600 dark:prose-a:text-blue-400 max-w-none">
          <Content />
        </div>
      </div>
    </div>

    <!-- Back to Blog -->
    <div class="max-w-4xl mx-auto px-4 py-16">
      <div class="border-t border-gray-200 dark:border-gray-700 pt-8">
        <a
          href="/"
          class="inline-flex items-center text-gray-600 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to all posts
        </a>
      </div>
    </div>

  </article>
</Layout>

<style is:global>
  /* Prose styling for markdown content */
  .prose img {
    @apply rounded-lg;
  }

  .prose a {
    @apply underline;
  }

  .prose code {
    @apply bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded;
  }

  .prose pre {
    @apply bg-gray-900 dark:bg-gray-800 rounded-lg overflow-x-auto;
  }

  .prose pre code {
    @apply bg-transparent px-0 py-0;
  }
</style>
