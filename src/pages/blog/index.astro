---
// =============================================================================
// BLOG LISTING PAGE - Simple blog listing using Astro Content Collections
// =============================================================================

import Layout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Fetch all published blog posts
const allPosts = await getCollection('blog', ({ data }) => data.status === 'published');
const posts = allPosts.sort((a, b) =>
  new Date(b.data.published_at).getTime() - new Date(a.data.published_at).getTime()
);

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  });
}

const pageTitle = 'Blog';
const pageDescription = 'Thoughts, tutorials, and stories about technology, travel, and life.';
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen bg-gray-50 dark:bg-gray-900">

    <!-- Hero Section -->
    <section class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="max-w-4xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-5xl font-light tracking-tight text-gray-900 dark:text-white mb-4">
            Blog
          </h1>
          <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
            {pageDescription}
          </p>
        </div>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">

      <!-- Posts List -->
      {posts.length > 0 ? (
        <div class="space-y-12">
          {posts.map((post) => (
            <article class="group">
              <a href={`/blog/${post.slug}`} class="block">
                {post.data.featured_image_url && (
                  <img
                    src={post.data.featured_image_url}
                    alt={post.data.title}
                    class="w-full h-64 object-cover rounded-lg mb-6"
                  />
                )}

                <div class="space-y-3">
                  <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
                    <time datetime={post.data.published_at.toISOString()}>
                      {formatDate(post.data.published_at)}
                    </time>
                    {post.data.reading_time && (
                      <>
                        <span>•</span>
                        <span>{post.data.reading_time} min read</span>
                      </>
                    )}
                  </div>

                  <h2 class="text-2xl font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                    {post.data.title}
                  </h2>

                  {post.data.excerpt && (
                    <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
                      {post.data.excerpt}
                    </p>
                  )}

                  <span class="inline-flex items-center text-blue-600 dark:text-blue-400 font-medium group-hover:underline">
                    Read more
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <!-- Empty State -->
        <div class="text-center py-16">
          <svg class="w-16 h-16 mx-auto text-gray-400 dark:text-gray-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-2">
            No posts yet
          </h3>
          <p class="text-gray-600 dark:text-gray-400">
            Check back soon for new content!
          </p>
        </div>
      )}

    </div>

  </main>
</Layout>
